{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],

  "prHourlyLimit": 5,

  "automergeType": "pr",
  "platformAutomerge": true,

  "git-submodules": {
    "enabled": true,
    "automerge": true
  },

  "docker-compose": {
    "enabled": false
  },

  "dockerfile": {
    "enabled": false
  },

  "github-actions": {
    "enabled": false
  },

  "packageRules": [
    {
      "matchPackageNames": ["https://github.com/otwcode/otwarchive"],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(\\.(?<build>\\d+))?$"
    }
  ]
}
